# Database
DB_PASSWORD=change-me-strong-password

# JWT Authentication
JWT_SECRET=change-me-to-a-random-64-char-string

# Claude API (for receipt OCR and AI Chat)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Shared secret for Telegram bot -> API internal calls
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_BOT_INTERNAL_SECRET=change-me-to-a-long-random-string

# OCR Mode: auto | cloud | ollama | offline | manual
OCR_MODE=auto

# Ollama (local LLM for receipt OCR — set to your LAN IP if running on another machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8002
